# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Lead discovery mode: mock, manual, or search.
# mock is deterministic and honest about being mock data.
LEAD_SOURCE_MODE=mock

# Search provider settings. Paid/API providers are scaffolded but disabled.
SEARCH_PROVIDER=seed_urls
SEARCH_LOCATION=Inverness, Scotland
SEARCH_MAX_RESULTS=10
SEARCH_SEED_URLS_PATH=data/search_seed_urls.txt
BRAVE_SEARCH_API_KEY=
GOOGLE_PLACES_API_KEY=

# Only QUALIFIED leads with score >= this value are eligible for Google Sheets.
MINIMUM_QUALIFICATION_SCORE=7

# Optional Google Sheets configuration.
# Optional/fallback only. DB-first Project 05 does not require Google Sheets.
GOOGLE_SHEETS_WRITE_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
GOOGLE_SHEETS_WORKSHEET_NAME=Leads
